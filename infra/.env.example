# ─────────────────────────────────────────────
#  Smart-Robe  ·  Environment Variables Template
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=smartrobe
POSTGRES_PASSWORD=changeme
POSTGRES_DB=smartrobe
DATABASE_URL=postgresql+asyncpg://smartrobe:changeme@postgres:5432/smartrobe

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Object storage (AWS S3 or compatible) ───────
S3_BUCKET=smart-robe-assets
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ── OpenAI ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pinecone ────────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENV=us-east1-gcp

# ── JWT Auth ────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Frontend ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
